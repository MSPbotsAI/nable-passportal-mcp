# ─── Passportal API Credentials (env mode only) ──────────────────────────────
# Passportal auth is OAuth2 client-credentials, HMAC-signed: this server
# exchanges a long-lived Access Key / Secret Access Key pair for a short-lived
# (~55 minute) bearer access token itself (see src/nable_passportal_mcp/auth.py)
# and caches it in-process. Not required when AUTH_MODE=gateway (credentials
# are provided per-request via headers instead).
PASSPORTAL_ACCESS_KEY=your_access_key
PASSPORTAL_SECRET_KEY=your_secret_access_key

# Customer instance base URL, e.g. https://instance.passportalmsp.com
# (the root of your Passportal dashboard URL, without a trailing slash).
# Not required when AUTH_MODE=gateway (provided per-request via header).
PASSPORTAL_BASE_URL=https://instance.passportalmsp.com

# HTTP header names that carry the credentials and instance base URL in
# gateway mode. The client must send ALL THREE headers on every /mcp request.
PASSPORTAL_ACCESS_KEY_HEADER=x-passportal-access-key
PASSPORTAL_SECRET_KEY_HEADER=x-passportal-secret-key
PASSPORTAL_BASE_URL_HEADER=x-passportal-base-url

# Scope requested at token-exchange time. Fixed by Passportal's Documents API;
# only override if a future tool set needs a different scope.
PASSPORTAL_TOKEN_SCOPE=docs_api

# ─── MCP Transport ───────────────────────────────────────────────────────────
# "http"  — stateless HTTP server (required for production / multi-tenant use)
# "stdio" — local stdio transport (useful for development / CLI use)
MCP_TRANSPORT=http
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# ─── Auth Mode ───────────────────────────────────────────────────────────────
# "gateway" — (default, SOP-compliant) credentials + base URL provided per-request via the
#             PASSPORTAL_ACCESS_KEY_HEADER / PASSPORTAL_SECRET_KEY_HEADER /
#             PASSPORTAL_BASE_URL_HEADER HTTP headers.
#             Required for production / multi-tenant deployments (e.g. behind mcp-gateway).
# "env"     — (local dev only) single credential pair + base URL loaded from environment
#             variables. NOT SOP-compliant: credentials are shared across all requests;
#             do not use in production.
AUTH_MODE=gateway
