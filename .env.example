# ─── Passportal API Credentials (env mode only) ──────────────────────────────
# Token used in env mode (single shared credential loaded from environment).
# Not required when AUTH_MODE=gateway (token is provided per-request via header).
PASSPORTAL_API_TOKEN=your_token_here

# Customer instance base URL, e.g. https://instance.passportalmsp.com
# (the root of your Passportal dashboard URL, without a trailing slash).
# Not required when AUTH_MODE=gateway (provided per-request via header).
PASSPORTAL_BASE_URL=https://instance.passportalmsp.com

# HTTP header names that carry the token and instance base URL in gateway mode.
# The client must send BOTH headers on every /mcp request.
PASSPORTAL_AUTH_HEADER=x-api-token
PASSPORTAL_BASE_URL_HEADER=x-passportal-base-url

# ─── MCP Transport ───────────────────────────────────────────────────────────
# "http"  — stateless HTTP server (required for production / multi-tenant use)
# "stdio" — local stdio transport (useful for development / CLI use)
MCP_TRANSPORT=http
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# ─── Auth Mode ───────────────────────────────────────────────────────────────
# "gateway" — (default, SOP-compliant) token + base URL provided per-request via the
#             PASSPORTAL_AUTH_HEADER / PASSPORTAL_BASE_URL_HEADER HTTP headers.
#             Required for production / multi-tenant deployments (e.g. behind mcp-gateway).
# "env"     — (local dev only) single token + base URL loaded from environment variables.
#             NOT SOP-compliant: token is shared across all requests; do not use in production.
AUTH_MODE=gateway
